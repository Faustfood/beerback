# Beerback Environment Variables
# Kopiere diese Datei zu .env.local und fülle die Werte aus
# WICHTIG: .env.local NIEMALS in Git committen!

# Supabase (aus Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-Side (geheim, niemals public exposed!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (lokal: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
